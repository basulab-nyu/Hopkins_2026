imagesc([sb(1) sb(end)], [1 n_OCGOLA], S1_OCGOLA)
colormap(s3, cmap_blue)
caxis([0 1])
ylabel('Neuron')
title('A')
xline(sb(70),'k--','LineWidth',2)

cb2 = colorbar;
cb2.Position = [leftMargin - colorbarGap - colorbarWidth, ...
                rowBottom(2), ...
                colorbarWidth, ...
                rowHeights(2)];

