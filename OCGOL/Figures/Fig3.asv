imagesc([sb(1) sb(end)], [1 n_OCGOLA], S2_OCGOLA)
colormap(s4, cmap_blue)
caxis([0 1])
title('A')
xline(sb(70),'k--','LineWidth',2)

% ==============================
% OCGOL-B ROW
